@model RoomBooking.Models.User
@{
    ViewData["Title"] = "Detail User";
}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header py-3 px-4 d-flex justify-content-between">
                <h5 class="mb-0 fw-bold"><i class="fas fa-user me-2 text-primary"></i>Detail User</h5>
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-warning">
                        <i class="fas fa-edit me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Kembali</a>
                </div>
            </div>
            <div class="card-body px-4 py-4">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="bg-light rounded p-3">
                            <div class="text-muted small">Nama Lengkap</div>
                            <div class="fw-semibold">@Model.FullName</div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="bg-light rounded p-3">
                            <div class="text-muted small">Email</div>
                            <div class="fw-semibold">@Model.Email</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="bg-light rounded p-3">
                            <div class="text-muted small">Role</div>
                            <span class="badge @(Model.Role == "Admin" ? "bg-danger" : "bg-primary") mt-1">@Model.Role</span>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="bg-light rounded p-3">
                            <div class="text-muted small">Status</div>
                            <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary") mt-1">@(Model.IsActive ? "Aktif" : "Nonaktif")</span>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="bg-light rounded p-3">
                            <div class="text-muted small">Bergabung</div>
                            <div class="fw-semibold">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header py-3 px-4">
                <h6 class="mb-0 fw-bold">Riwayat Booking (@Model.Bookings.Count)</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="bg-light"><tr><th class="px-4">Ruangan</th><th>Tanggal</th><th>Keperluan</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var b in Model.Bookings.OrderByDescending(x => x.BookingDate))
                        {
                            <tr>
                                <td class="px-4">@b.Room?.Name</td>
                                <td>@b.BookingDate.ToString("dd/MM/yyyy") @b.StartTime-@b.EndTime</td>
                                <td>@b.Purpose</td>
                                <td><span class="badge @(b.Status == "Approved" ? "bg-success" : b.Status == "Pending" ? "bg-warning text-dark" : "bg-secondary")">@b.Status</span></td>
                            </tr>
                        }
                        @if (!Model.Bookings.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">Belum ada booking</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
