@model RoomBooking.ViewModels.UserCreateViewModel
@{
    ViewData["Title"] = "Tambah User";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header py-3 px-4">
                <h5 class="mb-0 fw-bold"><i class="fas fa-user-plus me-2 text-primary"></i>Tambah User Baru</h5>
            </div>
            <div class="card-body px-4 py-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold">Nama Lengkap *</label>
                        <input asp-for="FullName" class="form-control" placeholder="Masukkan nama lengkap"/>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email *</label>
                        <input asp-for="Email" class="form-control" placeholder="user@example.com"/>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold">Password *</label>
                        <div class="input-group">
                            <input asp-for="Password" type="password" class="form-control"
                                   placeholder="Min. 8 karakter" id="passwordInput" />
                            <button type="button" class="btn btn-outline-secondary" onclick="togglePassword()">
                                <i class="fas fa-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Role" class="form-label fw-semibold">Role *</label>
                        <select asp-for="Role" class="form-select">
                            <option value="User">User</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Simpan</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Kembali</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>