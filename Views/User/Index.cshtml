@model List<RoomBooking.Models.User>
@{
    ViewData["Title"] = "Kelola User";
}

<div class="card">
    <div class="card-header py-3 px-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold"><i class="fas fa-users me-2 text-primary"></i>Kelola User</h5>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="fas fa-user-plus me-1"></i>Tambah User
        </a>
    </div>
    <div class="card-header py-2 px-4 bg-light border-top-0">
        <form method="get" class="d-flex gap-2">
            <input type="search" name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Cari nama atau email..." style="max-width:280px"/>
            <button type="submit" class="btn btn-sm btn-outline-primary">Cari</button>
        </form>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="px-4">#</th>
                    <th>Nama</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Terdaftar</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                @{int i = 1;}
                @foreach (var u in Model)
                {
                    <tr>
                        <td class="px-4">@i</td>
                        <td class="fw-semibold">@u.FullName</td>
                        <td>@u.Email</td>
                        <td>
                            <span class="badge @(u.Role == "Admin" ? "bg-danger" : "bg-primary")">@u.Role</span>
                        </td>
                        <td>
                            <span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">
                                @(u.IsActive ? "Aktif" : "Nonaktif")
                            </span>
                        </td>
                        <td>@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Detail" asp-route-id="@u.Id" class="btn btn-xs btn-outline-info"><i class="fas fa-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-xs btn-outline-warning"><i class="fas fa-edit"></i></a>
                                <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button onclick="return confirm('Hapus user @u.FullName?')" class="btn btn-xs btn-outline-danger">
                                        <i class="fas fa-ban"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    i++;
                }
            </tbody>
        </table>
    </div>
</div>
<style>.btn-xs{padding:2px 7px;font-size:.75rem}</style>
