@model RoomBooking.ViewModels.UserEditViewModel
@{
    ViewData["Title"] = "Edit User";
}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header py-3 px-4">
                <h5 class="mb-0 fw-bold"><i class="fas fa-user-edit me-2 text-warning"></i>Edit User</h5>
            </div>
            <div class="card-body px-4 py-4">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden"/>
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold">Nama Lengkap *</label>
                        <input asp-for="FullName" class="form-control"/>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email *</label>
                        <input asp-for="Email" class="form-control"/>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold">Password Baru <small class="text-muted">(kosongkan jika tidak ingin ganti)</small></label>
                        <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••"/>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Role" class="form-label fw-semibold">Role *</label>
                        <select asp-for="Role" class="form-select">
                            <option value="User">User</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div class="mb-4 form-check">
                        <input asp-for="IsActive" type="checkbox" class="form-check-input"/>
                        <label asp-for="IsActive" class="form-check-label">User Aktif</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning"><i class="fas fa-save me-1"></i>Update</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Kembali</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
