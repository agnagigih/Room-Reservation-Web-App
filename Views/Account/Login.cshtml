@model RoomBooking.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Login - Room Booking System</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
    <style>
        body {
            background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 60%, #60a5fa 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            padding: 48px 40px;
            width: 100%;
            max-width: 440px;
        }
        .login-icon {
            width: 64px; height: 64px;
            background: linear-gradient(135deg, #2563eb, #1e3a5f);
            border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 24px;
            color: #fff; font-size: 1.75rem;
        }
        .form-control:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.15); }
        .btn-login { background: linear-gradient(135deg, #1e3a5f, #2563eb); border: none; padding: 12px; font-size: 1rem; font-weight: 600; border-radius: 10px; }
        .btn-login:hover { opacity: 0.92; }
        .input-group-text { background: #f8fafc; border-right: none; }
        .form-control { border-left: none; }
    </style>
</head>
<body>
<div class="login-card">
    <div class="login-icon"><i class="fas fa-building"></i></div>
    <h4 class="text-center fw-bold mb-1">Room Booking System</h4>
    <p class="text-center text-muted mb-4">Silakan masuk untuk melanjutkan</p>

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Email</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                <input asp-for="Email" class="form-control" placeholder="admin@roombooking.com"/>
            </div>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Password</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                <input asp-for="Password" class="form-control" placeholder="••••••••" id="passwordInput"/>
                <button type="button" class="btn btn-outline-secondary" onclick="togglePwd()">
                    <i class="fas fa-eye" id="eyeIcon"></i>
                </button>
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-login btn-primary w-100 text-white">
            <i class="fas fa-sign-in-alt me-2"></i>Masuk
        </button>
    </form>

    <div class="mt-4 p-3 bg-light rounded text-center">
        <small class="text-muted">
            <strong>Demo Login:</strong><br/>
            Admin: admin@roombooking.com / Admin@123
        </small>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
<script>
function togglePwd() {
    const input = document.getElementById('passwordInput');
    const icon = document.getElementById('eyeIcon');
    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
    }
}
</script>
</body>
</html>
