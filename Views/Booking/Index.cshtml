@model RoomBooking.ViewModels.BookingFilterViewModel
@{
    ViewData["Title"] = "Booking Ruangan";
}

<div class="card">
    <div class="card-header py-3 px-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold"><i class="fas fa-calendar-check me-2 text-primary"></i>Booking Ruangan</h5>
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i>Buat Booking
            </a>
        </div>
        <form method="get" class="row g-2">
            <!-- Filter by Date -->
            <div class="col-md-3">
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                    <input type="date" name="filterDate" class="form-control"
                           value="@(Model.FilterDate?.ToString("yyyy-MM-dd") ?? "")"
                           placeholder="Filter Tanggal" />
                </div>
            </div>
            <!-- Filter by Room -->
            <div class="col-md-3">
                <select name="filterRoomId" class="form-select form-select-sm">
                    <option value="">-- Semua Ruangan --</option>
                    @foreach (var r in Model.Rooms)
                    {
                        if (Model.FilterRoomId == r.Id)
                        {
                            <option value="@r.Id" selected>@r.Name</option>
                        }
                        else
                        {
                            <option value="@r.Id">@r.Name</option>
                        }
                    }
                </select>
            </div>
            <!-- Filter by Status -->
            <div class="col-md-2">
                <select name="filterStatus" class="form-select form-select-sm">
                    <option value="">-- Semua Status --</option>
                    @foreach (var s in new[] { "Pending", "Approved", "Rejected", "Cancelled" })
                    {
                        if (Model.FilterStatus == s)
                        {
                            <option value="@s" selected>@s</option>
                        }
                        else
                        {
                            <option value="@s">@s</option>
                        }
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search me-1"></i>Filter</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-1">Reset</a>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4">#</th>
                        <th>Pemohon</th>
                        <th>Ruangan</th>
                        <th>Tanggal</th>
                        <th>Jam</th>
                        <th>Keperluan</th>
                        <th>Status</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int no = 1;
                    }
                    @foreach (var b in Model.Bookings)
                    {
                        <tr>
                            <td class="px-4 text-muted">@no</td>
                            <td>
                                <div class="fw-semibold">@b.User?.FullName</div>
                                <small class="text-muted">@b.CreatedAt.ToString("dd/MM/yy HH:mm")</small>
                            </td>
                            <td>
                                <div>@b.Room?.Name</div>
                                <small class="text-muted">@b.Room?.Location</small>
                            </td>
                            <td>@b.BookingDate.ToString("dd MMM yyyy")</td>
                            <td>@b.StartTime – @b.EndTime</td>
                            <td>
                                <span title="@b.Notes">@(b.Purpose.Length > 30 ? b.Purpose.Substring(0, 30) + "..." : b.Purpose)</span>
                            </td>
                            <td>
                                @{
                                    var cls = b.Status switch
                                    {
                                                    "Approved" => "bg-success",
                                                    "Pending" => "bg-warning text-dark",
                                                    "Rejected" => "bg-danger",
                                                    "Cancelled" => "bg-secondary",
                                        _ => "bg-light text-dark"
                                    };
                                }
                                <span class="badge @cls">@b.Status</span>
                            </td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    <a asp-action="Detail" asp-route-id="@b.Id" class="btn btn-xs btn-outline-info" title="Detail">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (b.Status == "Pending" && (User.IsInRole("Admin") || b.UserId.ToString() == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value))
                                    {
                                        <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-xs btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin") && b.Status == "Pending")
                                    {
                                        <form asp-action="Approve" asp-route-id="@b.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-xs btn-outline-success" title="Setujui"
                                                    onclick="return confirm('Setujui booking ini?')">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                        <form asp-action="Reject" asp-route-id="@b.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-xs btn-outline-danger" title="Tolak"
                                                    onclick="return confirm('Tolak booking ini?')">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (b.Status is "Pending" or "Approved")
                                    {
                                        <form asp-action="Cancel" asp-route-id="@b.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-xs btn-outline-secondary" title="Batalkan"
                                                    onclick="return confirm('Batalkan booking ini?')">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-action="Delete" asp-route-id="@b.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-xs btn-danger" title="Hapus"
                                                    onclick="return confirm('Hapus permanen booking ini?')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                        no++;
                    }
                    @if (!Model.Bookings.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="fas fa-calendar-xmark fa-2x mb-2 d-block"></i>
                                Tidak ada booking ditemukan
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .btn-xs {
        padding: 2px 7px;
        font-size: 0.75rem;
    }
</style>