@model RoomBooking.ViewModels.BookingCreateViewModel
@{
    ViewData["Title"] = "Buat Booking";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header py-3 px-4">
                <h5 class="mb-0 fw-bold"><i class="fas fa-calendar-plus me-2 text-primary"></i>Buat Booking Ruangan</h5>
            </div>
            <div class="card-body px-4 py-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="RoomId" class="form-label fw-semibold">Ruangan <span class="text-danger">*</span></label>
                        <select asp-for="RoomId" class="form-select">
                            <option value="">-- Pilih Ruangan --</option>
                            @foreach (var r in Model.AvailableRooms)
                            {
                                <option value="@r.Id">@r.Name — @r.Location (kapasitas @r.Capacity orang)</option>
                            }
                        </select>
                        <span asp-validation-for="RoomId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BookingDate" class="form-label fw-semibold">Tanggal Booking <span class="text-danger">*</span></label>
                        <input asp-for="BookingDate" type="date" class="form-control"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"/>
                        <span asp-validation-for="BookingDate" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label asp-for="StartTime" class="form-label fw-semibold">Jam Mulai <span class="text-danger">*</span></label>
                            <input asp-for="StartTime" type="time" class="form-control" min="07:00" max="20:00"/>
                            <span asp-validation-for="StartTime" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="EndTime" class="form-label fw-semibold">Jam Selesai <span class="text-danger">*</span></label>
                            <input asp-for="EndTime" type="time" class="form-control" min="07:00" max="21:00"/>
                            <span asp-validation-for="EndTime" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Purpose" class="form-label fw-semibold">Keperluan <span class="text-danger">*</span></label>
                        <input asp-for="Purpose" class="form-control" placeholder="Contoh: Rapat Tim Marketing Q1 2025"/>
                        <span asp-validation-for="Purpose" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label fw-semibold">Catatan Tambahan</label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Kebutuhan tambahan, peralatan, dll."></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Simpan Booking
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Kembali
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
