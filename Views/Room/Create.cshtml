@model RoomBooking.Models.Room
@{
    ViewData["Title"] = "Tambah Ruangan";
}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header py-3 px-4">
                <h5 class="mb-0 fw-bold"><i class="fas fa-door-open me-2 text-primary"></i>Tambah Ruangan</h5>
            </div>
            <div class="card-body px-4 py-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Nama Ruangan *</label>
                        <input asp-for="Name" class="form-control" placeholder="Contoh: Ruang Rapat Utama"/>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-semibold">Lokasi *</label>
                        <input asp-for="Location" class="form-control" placeholder="Contoh: Lantai 2"/>
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label fw-semibold">Kapasitas (orang) *</label>
                        <input asp-for="Capacity" type="number" class="form-control" min="1"/>
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold">Deskripsi</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Fasilitas, kondisi ruangan, dll."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Simpan</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Kembali</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
