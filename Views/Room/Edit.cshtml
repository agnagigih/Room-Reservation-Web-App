@model RoomBooking.Models.Room
@{
    ViewData["Title"] = "Edit Ruangan";
}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header py-3 px-4">
                <h5 class="mb-0 fw-bold"><i class="fas fa-edit me-2 text-warning"></i>Edit Ruangan</h5>
            </div>
            <div class="card-body px-4 py-4">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden"/>
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Nama Ruangan *</label>
                        <input asp-for="Name" class="form-control"/>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-semibold">Lokasi *</label>
                        <input asp-for="Location" class="form-control"/>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label fw-semibold">Kapasitas *</label>
                        <input asp-for="Capacity" type="number" class="form-control" min="1"/>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Deskripsi</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-4 form-check">
                        <input asp-for="IsActive" type="checkbox" class="form-check-input"/>
                        <label asp-for="IsActive" class="form-check-label">Ruangan Aktif</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning"><i class="fas fa-save me-1"></i>Update</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Kembali</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
