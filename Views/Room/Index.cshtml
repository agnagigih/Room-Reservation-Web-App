@model List<RoomBooking.Models.Room>
@{
    ViewData["Title"] = "Daftar Ruangan";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="fas fa-door-open me-2 text-primary"></i>Daftar Ruangan</h5>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Tambah Ruangan</a>
    }
</div>

<form method="get" class="mb-3">
    <div class="input-group" style="max-width:300px">
        <input type="search" name="search" value="@ViewBag.Search" class="form-control" placeholder="Cari ruangan..."/>
        <button type="submit" class="btn btn-outline-primary">Cari</button>
    </div>
</form>

<div class="row g-3">
    @foreach (var r in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 @(!r.IsActive ? "opacity-50" : "")">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="fw-bold mb-0">@r.Name</h6>
                        <span class="badge @(r.IsActive ? "bg-success" : "bg-secondary")">@(r.IsActive ? "Aktif" : "Nonaktif")</span>
                    </div>
                    <div class="text-muted small mb-2"><i class="fas fa-map-marker-alt me-1"></i>@r.Location</div>
                    <div class="text-muted small mb-2"><i class="fas fa-users me-1"></i>Kapasitas @r.Capacity orang</div>
                    @if (!string.IsNullOrEmpty(r.Description))
                    {
                        <p class="small mb-3">@r.Description</p>
                    }
                    <div class="d-flex gap-1 mt-auto">
                        <a asp-action="Detail" asp-route-id="@r.Id" class="btn btn-sm btn-outline-info">
                            <i class="fas fa-eye me-1"></i>Detail
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            @if (r.IsActive)
                            {
                                <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button onclick="return confirm('Nonaktifkan ruangan ini?')" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-ban"></i>
                                    </button>
                                </form>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">Belum ada ruangan tersedia</div>
    }
</div>
